@model ProductFilterViewModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<h2>Lista de Produtos</h2>

<form method="get">
    <select name="filterType" onchange="this.form.submit()">
        <option value="">Selecione o Tipo</option>
        <option value="category" selected = "@(Model.FilterType == "category")"
            >Categorias
        </option>
        <option value="supplier" selected="@(Model.FilterType == "supplier")">
            Fornecedores
        </option>
    </select>

    @if(Model.FilterType == "category")
    {
        <select name="filterId" onchange="this.form.submit()">
            <option value="">Selecione a Categoria</option>
            @foreach(var categoria in Model.Categories){
                <option value="@categoria.CategoryId" selected="@(Model.FilterId == categoria.CategoryId)">
                    @categoria.CategoryName
                </option>
            }
        </select>
    })

    @if (Model.FilterType == "supplier")
    {
        <select name="filterId" onchange="this.form.submit()">
            <option>Seleciono o Fornecedor</option>
            @foreach(var fornecedor in Model.Supliers)
            {
                <option value="@fornecedor.SupplierId" selected="@(Model.FilterId == fornecedor.SupplierId)">
                    @fornecedor.CompanyName
                </option>
            }
        </select>
    }
</form>

<table>
    <thead>
        <tr>
            <th>Produtos</th>
            <th>Preços</th>
            <th>Categorias</th>
            <th>Fornecedor</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var products in Model.Products)
        {
            <tr>
                <td>@products.Nome</td>
                <td>@products.Preco</td>
                <td>@products.Categoria</td>
                <td>@products.Fornecedor</td>
            </tr>
        }
    </tbody>
</table>
